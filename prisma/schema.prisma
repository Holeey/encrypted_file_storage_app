generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  files     File[]
}

model File {
  id         String   @id @default(uuid())
  name       String
  size       Int
  path       String
  iv         String
  userId     String
  createdAt  DateTime @default(now())
  checksum   String?
  keyVersion Int      @default(1)
  mimeType   String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
